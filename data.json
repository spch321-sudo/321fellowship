{
  "contentVersion": "1.1.0",
  "verses": [
    {
      "ref": "加二20",
      "text": "我已經與基督同釘十字架，現在活著的不再是我，乃是基督在我裡面活著。",
      "motto": "無己不是沒有，乃是進入無限、活出無限"
    },
    {
      "ref": "雅四6",
      "text": "神阻擋驕傲的人，賜恩給謙卑的人。",
      "motto": "謙卑是復興的鑰匙"
    },
    {
      "ref": "弗四3",
      "text": "用和平彼此聯絡，竭力保守聖靈所賜合而為一的心。",
      "motto": "無己才能合一"
    },
    {
      "ref": "提後二2",
      "text": "你在許多見證人面前聽見我所教訓的，也要交託那忠心能教導別人的人。",
      "motto": "235：生命要繁殖生命"
    },
    {
      "ref": "加五22",
      "text": "聖靈所結的果子，就是仁愛、喜樂、和平、忍耐、恩慈、良善、信實。",
      "motto": "920：活出九樣果子的基督生命"
    },
    {
      "ref": "箴四23",
      "text": "你要保守你心，勝過保守一切，因為一生的果效是由心發出。",
      "motto": "用心靠聖靈，不用腦靠自己"
    },
    {
      "ref": "太二八19",
      "text": "所以，你們要去，使萬民作我的門徒。",
      "motto": "每一位家人，都是被差派的"
    },
    {
      "ref": "約十五5",
      "text": "我是葡萄樹，你們是枝子……因為離了我，你們就不能做甚麼。",
      "motto": "無己才能讓耶穌在裡面活"
    },
    {
      "ref": "腓二3",
      "text": "只要存心謙卑，各人看別人比自己強。",
      "motto": "謙卑帶動謙卑，達到雙贏"
    },
    {
      "ref": "彼前五6",
      "text": "你們要自卑，服在神大能的手下，到了時候，他必叫你們升高。",
      "motto": "放下權力，回到本位"
    },
    {
      "ref": "羅十二5",
      "text": "我們這許多人，在基督裡成為一身，互相聯絡作肢體。",
      "motto": "無己才能合一，合一才能建立體系"
    },
    {
      "ref": "約壹四18",
      "text": "愛裡沒有懼怕；愛既完全，就把懼怕除去。",
      "motto": "完全的愛，趕出一切懼怕"
    },
    {
      "ref": "太十六24",
      "text": "若有人要跟從我，就當捨己，背起他的十字架來跟從我。",
      "motto": "捨己：為耶穌、為別人，不為自己"
    },
    {
      "ref": "林前三6",
      "text": "我栽種了，亞波羅澆灌了，惟有神叫他生長。",
      "motto": "一切都是神在耶穌裡所成就的"
    },
    {
      "ref": "詩一二七1",
      "text": "若不是耶和華建造房屋，建造的人就枉然勞力。",
      "motto": "讓耶穌作王，親自建造"
    },
    {
      "ref": "約三30",
      "text": "他必興旺，我必衰微。",
      "motto": "焦點在耶穌，不在自己"
    },
    {
      "ref": "太六10",
      "text": "願你的國降臨；願你的旨意行在地上，如同行在天上。",
      "motto": "建立屬神的體系，成就主禱文"
    },
    {
      "ref": "代下七14",
      "text": "這稱為我名下的子民，若是自卑、禱告，尋求我的面……我必醫治他們的地。",
      "motto": "自卑禱告，帶下醫治與復興"
    },
    {
      "ref": "賽四二3",
      "text": "壓傷的蘆葦，他不折斷；將殘的燈火，他不吹滅。",
      "motto": "主接住每一個受傷的靈魂"
    },
    {
      "ref": "腓四13",
      "text": "我靠著那加給我力量的，凡事都能做。",
      "motto": "靠耶穌的能力，反敗為勝"
    },
    {
      "ref": "羅八37",
      "text": "然而，靠著愛我們的主，在這一切的事上已經得勝有餘了。",
      "motto": "我們是得勝者"
    },
    {
      "ref": "加二20b",
      "text": "並且我如今在肉身活著，是因信神的兒子而活；他是愛我，為我捨己。",
      "motto": "因信而活，因祂捨己"
    },
    {
      "ref": "約十三34",
      "text": "我賜給你們一條新命令，乃是叫你們彼此相愛。",
      "motto": "920：每個與我有關係的人是我的2"
    },
    {
      "ref": "箴三5",
      "text": "你要專心仰賴耶和華，不可倚靠自己的聰明。",
      "motto": "用心靠聖靈，不用腦靠自己"
    },
    {
      "ref": "腓一6",
      "text": "那在你們心裡動了善工的，必成全這工，直到耶穌基督的日子。",
      "motto": "神必親自成全祂所動的善工"
    },
    {
      "ref": "太五16",
      "text": "你們的光也當這樣照在人前，叫他們……將榮耀歸給你們在天上的父。",
      "motto": "讓耶穌得一切的榮耀"
    },
    {
      "ref": "弗四16",
      "text": "全身都靠他聯絡得合式……便叫身體漸漸增長，在愛中建立自己。",
      "motto": "肢體彼此相助，身體漸漸增長"
    },
    {
      "ref": "詩九十17",
      "text": "願主我們神的榮美歸於我們身上；願你堅立我們手所做的工。",
      "motto": "願主堅立我們手所做的工"
    },
    {
      "ref": "約十七21",
      "text": "使他們都合而為一……叫世人可以信你差了我來。",
      "motto": "合一，是給世界最有力的見證"
    },
    {
      "ref": "啟二一5",
      "text": "看哪，我將一切都更新了。",
      "motto": "在基督裡，舊人變新人"
    }
  ],
